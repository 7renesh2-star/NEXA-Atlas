class AsyncWorkerPool:
    """Async worker pool for handling multiple users concurrently"""
    
    def __init__(self, model: SelfLearningModel, tokenizer, num_workers: int = 4):
        self.model = model
        self.tokenizer = tokenizer
        self.num_workers = num_workers
        self.task_queue = asyncio.Queue(maxsize=1000)
        self.results = {}
        self.workers = []
        
        # Start workers
        self._start_workers()
        
        logger.info(f"⚡ AsyncWorkerPool started with {num_workers} workers")
    
    def _start_workers(self):
        """Start async worker tasks"""
        async def worker(worker_id: int):
            while True:
                try:
                    task_id, user_id, message, history = await self.task_queue.get()
                    
                    # Process message
                    start_time = time.time()
                    response = await self._generate_response(message, history)
                    latency = (time.time() - start_time) * 1000
                    
                    # Store result
                    self.results[task_id] = {
                        'response': response,
                        'latency_ms': latency,
                        'worker_id': worker_id
                    }
                    
                    # Log conversation
                    tokens = len(self.tokenizer.encode(message + response))
                    database.log_conversation(user_id, message, response, tokens, latency)
                    
                    self.task_queue.task_done()
                    
                except asyncio.CancelledError:
                    break
                except Exception as e:
                    logger.error(f"Worker {worker_id} error: {e}")
        
        for i in range(self.num_workers):
            worker_task = asyncio.create_task(worker(i))
            self.workers.append(worker_task)
    
    async def _generate_response(self, message: str, history: List[Dict]) -> str:
        """Generate response using the model"""
        
        # Format prompt
        prompt = self._format_prompt(message, history)
        
        # Tokenize
        input_ids = self.tokenizer.encode(prompt, return_tensors="pt").to(DEVICE)
        
        # Generate
        with torch.no_grad():
            generated_ids = self.model.generate(
                input_ids,
                max_new_tokens=200,
                temperature=0.7,
                top_k=50,
                top_p=0.95
            )
        
        # Decode
        response = self.tokenizer.decode(generated_ids[0], skip_special_tokens=True)
        
        # Extract assistant response
        if "Assistant:" in response:
            response = response.split("Assistant:")[-1].strip()
        else:
            response = response[len(prompt):].strip()
        
        return response or "I understand. How can I help you further?"
    
    def _format_prompt(self, message: str, history: List[Dict]) -> str:
        """Format conversation prompt"""
        prompt = ""
        
        # Add system message
        prompt += "You are NEXA Atlas, a helpful AI assistant.\n\n"
        
        # Add conversation history
        for turn in history[-5:]:  # Last 5 turns for context
            if turn['role'] == 'user':
                prompt += f"User: {turn['content']}\n"
            else:
                prompt += f"Assistant: {turn['content']}\n"
        
        # Add current message
        prompt += f"User: {message}\nAssistant:"
        
        return prompt
    
    async def submit_task(self, user_id: str, message: str, history: List[Dict]) -> Dict:
        """Submit a task to the worker pool"""
        task_id = hashlib.md5(f"{user_id}{time.time()}".encode()).hexdigest()
        
        await self.task_queue.put((task_id, user_id, message, history))
        
        # Wait for result
        while task_id not in self.results:
            await asyncio.sleep(0.01)
        
        result = self.results.pop(task_id)
        return result


