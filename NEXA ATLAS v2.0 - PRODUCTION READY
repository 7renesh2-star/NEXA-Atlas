def create_app() -> FastAPI:
    """Create FastAPI application with all features"""
    
    app = FastAPI(
        title="NEXA Atlas v2.0",
        description="Production Multi-User AI Chatbot with Self-Training",
        version="6.0.0"
    )
    
    # CORS
    app.add_middleware(
        CORSMiddleware,
        allow_origins=["*"],
        allow_credentials=True,
        allow_methods=["*"],
        allow_headers=["*"],
    )
    
    @app.on_event("startup")
    async def startup():
        """Initialize all components on startup"""
        global model, tokenizer, worker_pool, training_system, cloud_sync
        
        logger.info("🚀 Starting NEXA Atlas v2.0...")
        
        # Load REAL pretrained model
        try:
            # Try GPT-2 first (works everywhere)
            tokenizer = GPT2Tokenizer.from_pretrained('gpt2')
            tokenizer.pad_token = tokenizer.eos_token
            
            # Use our enhanced model with real architecture
            model = SelfLearningModel(
                vocab_size=50257,
                d_model=768,
                n_layers=12,
                n_heads=12
            ).to(DEVICE)
            
            # Load pretrained weights from GPT-2 if available
