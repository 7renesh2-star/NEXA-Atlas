class SelfTrainingSystem:
    """NCPS - Neural Continuous Pre-training System"""
    
    def __init__(self, model: SelfLearningModel, tokenizer):
        self.model = model
        self.tokenizer = tokenizer
        self.optimizer = AdamW(model.parameters(), lr=5e-5, weight_decay=0.01)
        
        # Training state
        self.training_batch_size = 4
        self.gradient_accumulation_steps = 4
        self.max_grad_norm = 1.0
        
        # Background training thread
        self.training_queue = queue.Queue()
        self.is_training = False
        self.training_thread = None
        
        # Performance tracking
        self.performance_history = deque(maxlen=100)
        
        logger.info("🔄 NCPS Self-Training System initialized")
    
    def collect_training_data(self, user_id: str, prompt: str, response: str, rating: int):
        """Collect interaction data for training"""
        self.training_queue.put({
            'user_id': user_id,
            'prompt': prompt,
            'response': response,
            'rating': rating,
            'timestamp': time.time()
        })
    
    def start_background_training(self, interval_seconds: int = 300):
        """Start background training thread"""
        
        def train_loop():
            while True:
                time.sleep(interval_seconds)
                try:
                    self._train_on_collected_data()
                except Exception as e:
                    logger.error(f"Background training error: {e}")
        
        self.training_thread = threading.Thread(target=train_loop, daemon=True)
        self.training_thread.start()
        logger.info(f"🔄 Background training started (interval={interval_seconds}s)")
    
    def _train_on_collected_data(self):
        """Train on collected user interactions"""
        
        training_items = []
        while not self.training_queue.empty():
            try:
                item = self.training_queue.get_nowait()
                training_items.append(item)
            except queue.Empty:
                break
        
        if len(training_items) < 10:
            return
        
        logger.info(f"📚 Training on {len(training_items)} interactions")
        
        # Convert to training format
        training_texts = []
        for item in training_items:
            if item['rating'] >= 4:  # High-rated responses for positive training
                training_texts.append(f"User: {item['prompt']}\nAssistant: {item['response']}")
        
        if not training_texts:
            return
        
        # Tokenize
        encodings = self.tokenizer(
            training_texts,
            truncation=True,
            padding=True,
            max_length=512,
            return_tensors="pt"
        )
        
        # Training loop
        self.model.train()
        self.optimizer.zero_grad()
        
        for i in range(0, len(encodings['input_ids']), self.training_batch_size):
            batch = {k: v[i:i+self.training_batch_size].to(DEVICE) 
                    for k, v in encodings.items()}
            
            # Forward pass
            logits, _ = self.model(batch['input_ids'])
            loss = F.cross_entropy(
                logits.view(-1, self.model.vocab_size),
                batch['input_ids'].view(-1)
            )
            
            # Backward pass
            loss.backward()
            
            if (i // self.training_batch_size) % self.gradient_accumulation_steps == 0:
                torch.nn.utils.clip_grad_norm_(self.model.parameters(), self.max_grad_norm)
                self.optimizer.step()
                self.optimizer.zero_grad()
        
        self.model.eval()
        logger.info(f"✅ Training completed, loss: {loss.item():.4f}")
        
        # Save checkpoint
        self._save_checkpoint()
    
    def _save_checkpoint(self):
        """Save model checkpoint"""
        checkpoint_path = Path(f"checkpoints/model_{int(time.time())}.pt")
        checkpoint_path.parent.mkdir(exist_ok=True)
        
        torch.save({
            'model_state_dict': self.model.state_dict(),
            'optimizer_state_dict': self.optimizer.state_dict(),
            'timestamp': time.time()
        }, checkpoint_path)
        
        logger.info(f"💾 Checkpoint saved: {checkpoint_path}")


