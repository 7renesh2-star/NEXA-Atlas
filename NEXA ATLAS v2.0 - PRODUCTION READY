class Database:
    """SQLite database for multi-user persistence"""
    
    def __init__(self, db_path: str = "nexa.db"):
        self.db_path = db_path
        self._init_db()
        
    def _init_db(self):
        """Initialize database tables"""
        with sqlite3.connect(self.db_path) as conn:
            cursor = conn.cursor()
            
            # Users table
            cursor.execute('''
                CREATE TABLE IF NOT EXISTS users (
                    user_id TEXT PRIMARY KEY,
                    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                    total_messages INTEGER DEFAULT 0,
                    total_tokens INTEGER DEFAULT 0,
                    last_active TIMESTAMP DEFAULT CURRENT_TIMESTAMP
                )
            ''')
            
            # Conversations table
            cursor.execute('''
                CREATE TABLE IF NOT EXISTS conversations (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    user_id TEXT,
                    message TEXT,
                    response TEXT,
                    tokens_used INTEGER,
                    latency_ms REAL,
                    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                    FOREIGN KEY (user_id) REFERENCES users(user_id)
                )
            ''')
            
            # Feedback table (for self-training)
            cursor.execute('''
                CREATE TABLE IF NOT EXISTS feedback (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    user_id TEXT,
                    prompt TEXT,
                    response TEXT,
                    rating INTEGER,
                            timestamp TIMESTAMP DEFAULT CURRENT_TIMESTAMP
                )
            ''')
            
            # Model states (for RLMS)
            cursor.execute('''
                CREATE TABLE IF NOT EXISTS model_states (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    model_version TEXT,
                    state BLOB,
                    performance_score REAL,
                    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
                )
            ''')
            
            conn.commit()
            logger.info("✅ Database initialized")
    
    def register_user(self, user_id: str) -> bool:
        """Register a new user"""
        with sqlite3.connect(self.db_path) as conn:
            cursor = conn.cursor()
            try:
                cursor.execute(
                    "INSERT INTO users (user_id) VALUES (?)",
                    (user_id,)
                )
                conn.commit()
                return True
            except sqlite3.IntegrityError:
                return False
    
    def log_conversation(self, user_id: str, message: str, response: str, 
                         tokens: int, latency: float):
        """Log conversation for training data"""
        with sqlite3.connect(self.db_path) as conn:
            cursor = conn.cursor()
            cursor.execute('''
                INSERT INTO conversations (user_id, message, response, tokens_used, latency_ms)
                VALUES (?, ?, ?, ?, ?)
            ''', (user_id, message, response, tokens, latency))
            
            cursor.execute('''
                UPDATE users SET total_messages = total_messages + 1,
                                 total_tokens = total_tokens + ?,
                                 last_active = CURRENT_TIMESTAMP
                WHERE user_id = ?
            ''', (tokens, user_id))
            
            conn.commit()
    
    def add_feedback(self, user_id: str, prompt: str, response: str, rating: int):
        """Add user feedback for training"""
        with sqlite3.connect(self.db_path) as conn:
            cursor = conn.cursor()
            cursor.execute('''
                INSERT INTO feedback (user_id, prompt, response, rating)
                VALUES (?, ?, ?, ?)
            ''', (user_id, prompt, response, rating))
            conn.commit()
    
    def get_training_data(self, limit: int = 10000) -> List[Tuple[str, str, int]]:
        """Get conversation data for self-training"""
        with sqlite3.connect(self.db_path) as conn:
            cursor = conn.cursor()
            
            # Get conversations with high ratings for positive examples
            cursor.execute('''
                SELECT c.message, c.response, COALESCE(f.rating, 0)
                FROM conversations c
                LEFT JOIN feedback f ON c.id = f.rowid
                ORDER BY c.created_at DESC
                LIMIT ?
            ''', (limit,))
            
            return cursor.fetchall()

