            except:
                logger.info("⚠️ Using randomly initialized weights (train with feedback to improve)")
            
            logger.info("✅ Model loaded successfully")
            
        except Exception as e:
            logger.error(f"Model loading error: {e}")
            raise
        
        # Initialize components
        worker_pool = AsyncWorkerPool(model, tokenizer, num_workers=4)
        training_system = SelfTrainingSystem(model, tokenizer)
        cloud_sync = CloudSyncModule()
        
        # Start background training
        training_system.start_background_training(interval_seconds=300)
        
        logger.info("✅ NEXA Atlas v2.0 ready!")
    
    @app.post("/chat", response_model=ChatResponse)
    async def chat(request: ChatRequest):
        """Chat endpoint with async processing"""
        
        REQUEST_COUNT.inc()
        ACTIVE_USERS.inc()
        
        with REQUEST_LATENCY.time():
            try:
                # Get or create user
                user_id = request.user_id or hashlib.md5(request.session_id.encode() if request.session_id else os.urandom(32)).hexdigest()[:16]
                
                # Register new user
                database.register_user(user_id)
                
                # Get conversation history
                history = user_sessions.get(user_id, [])
                
                # Process with worker pool
                result = await worker_pool.submit_task(user_id, request.message, history)
                
                # Update session history
                user_sessions[user_id].append({'role': 'user', 'content': request.message})
                user_sessions[user_id].append({'role': 'assistant', 'content': result['response']})
                
                # Trim history
                if len(user_sessions[user_id]) > 50:
                    user_sessions[user_id] = user_sessions[user_id][-50:]
                
                TOKENS_GENERATED.inc(result.get('tokens_used', 0))
                
                return ChatResponse(
                    response=result['response'],
                    user_id=user_id,
                    latency_ms=result['latency_ms'],
                    tokens_used=result.get('tokens_used', 0),
                    model_version="v2.0"
                )
                
            except Exception as e:
                logger.error(f"Chat error: {e}")
                raise HTTPException(status_code=500, detail=str(e))
            finally:
                ACTIVE_USERS.dec()
    
    @app.post("/feedback")
    async def feedback(request: FeedbackRequest):
        """Submit feedback for self-training"""
        
        # Collect for training
        training_system.collect_training_data(
            request.user_id,
            request.message,
            request.response,
            request.rating
        )
        
        # Store in database
        database.add_feedback(
            request.user_id,
            request.message,
            request.response,
            request.rating
        )
        
        return {"status": "success", "message": "Thank you for your feedback!"}
    
    @app.get("/stats")
    async def stats():
        """Get system statistics"""
        
        with sqlite3.connect(database.db_path) as conn:
            cursor = conn.cursor()
            
            cursor.execute("SELECT COUNT(*) FROM users")
            total_users = cursor.fetchone()[0]
            
            cursor.execute("SELECT SUM(total_messages) FROM users")
            total_messages = cursor.fetchone()[0] or 0
            
            cursor.execute("SELECT AVG(rating) FROM feedback WHERE rating > 0")
            avg_rating = cursor.fetchone()[0] or 0
        
        return {
            "total_users": total_users,
            "total_messages": total_messages,
            "active_sessions": len(user_sessions),
            "avg_user_rating": round(avg_rating, 2),
            "queue_size": worker_pool.task_queue.qsize() if worker_pool else 0,
            "device": str(DEVICE),
            "model_params": sum(p.numel() for p in model.parameters()) if model else 0
        }
    
    @app.get("/metrics")
    async def metrics():
        """Prometheus metrics endpoint"""
        from fastapi.responses import Response
        return Response(content=generate_latest(), media_type=CONTENT_TYPE_LATEST)
    
    @app.get("/health")
    async def health():
        """Health check"""
        return {
            "status": "healthy",
            "version": "6.0.0",
            "device": str(DEVICE),
            "model_loaded": model is not None,
            "timestamp": datetime.now().isoformat()
        }
    
    @app.post("/train/trigger")
    async def trigger_training():
        """Manually trigger self-training"""
        if training_system:
            await asyncio.get_event_loop().run_in_executor(
                None, training_system._train_on_collected_data
            )
            return {"status": "training_started"}
        return {"status": "training_not_available"}
    
    return app


